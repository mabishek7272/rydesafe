// TrackBuddy — Multi-Tenant Prisma Schema
// Datasource: PostgreSQL (replace SQLite for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum OrganisationType {
  SCHOOL
  CORPORATE
  FACTORY
  CHARTER
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  SCHOOL_ADMIN
  DISPATCHER
  OPS_MANAGER
  DRIVER
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  UNDER_REVIEW
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ScheduleType {
  PICKUP
  DROPOFF
  RECURRING
  ONE_TIME
  EXTRA
  SPECIAL
}

enum ScheduleStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TripStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripAction {
  PICKED_UP
  DROPPED
  ABSENT
  SELF_PICKUP
  BOARDING
}

enum NotificationChannel {
  FCM
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ImportType {
  EXCEL
  CSV
  OCR
}

enum LogSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  PREVIEW_READY
  APPROVED
  COMPLETED
  FAILED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── TENANT LAYER ─────────────────────────────────────────────────────────────

model Organisation {
  id           String           @id @default(cuid())
  name         String
  type         OrganisationType @default(SCHOOL)
  logoUrl      String?
  primaryColor String?
  settings     Json? // branding, feature flags, etc.
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  branches      Branch[]
  users         User[]
  passengers    Passenger[]
  vehicles      Vehicle[]
  routes        Route[]
  schedules     Schedule[]
  trips         Trip[]
  importJobs    ImportJob[]
  auditLogs     AuditLog[]
  notifications NotificationLog[]
}

model Branch {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  address        String?
  contactPhone   String?
  contactEmail   String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users      User[]
  passengers Passenger[]
  routes     Route[]
  schedules  Schedule[]
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])

  name         String
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  phone        String?
  locale       String?    @default("en")
  deviceId     String? // for FCM token binding
  fcmToken     String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  driverProfile DriverProfile?
  notifications NotificationLog[]
  auditActions  AuditLog[]        @relation("AuditActor")
  invitations   Invitation[]      @relation("InvitedBy")

  // Trip associations (as driver)
  tripsAsDriver Trip[]      @relation("TripDriver")
  tripEvents    TripEvent[] @relation("RecordedBy")

  // Parent link
  guardianOf Guardian[]
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  role           UserRole
  organisationId String
  branchId       String?
  token          String           @unique @default(cuid())
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  invitedBy      User             @relation("InvitedBy", fields: [invitedById], references: [id])
  createdAt      DateTime         @default(now())
}

// ─── DRIVER PROFILE ───────────────────────────────────────────────────────────

model DriverProfile {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id])
  organisationId String

  licenseNumber    String?
  licenseExpiry    DateTime?
  licenseImageUrl  String?
  address          String?
  emergencyContact String?
  status           DriverStatus @default(ACTIVE)
  testingNotes     String?

  vehicleAssignments VehicleAssignment[]
  driverShifts       DriverShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── VEHICLE MANAGEMENT ───────────────────────────────────────────────────────

model Vehicle {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  plateNumber  String
  make         String?
  model        String?
  year         Int?
  capacity     Int           @default(20)
  gpsDeviceId  String? // hardware GPS tracker ID
  wialonUnitId String? // Wialon unit ID for API queries
  status       VehicleStatus @default(ACTIVE)
  qrToken      String?

  vehicleAssignments VehicleAssignment[]
  maintenanceLogs    MaintenanceLog[]
  trips              Trip[]
  trackingSessions   TrackingSession[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Schedule  Schedule[]

  @@unique([organisationId, plateNumber])
}

model VehicleAssignment {
  id              String        @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id])
  driverProfileId String
  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
  assignedAt      DateTime      @default(now())
  unassignedAt    DateTime?
  isPrimary       Boolean       @default(true)
}

model MaintenanceLog {
  id            String            @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])
  type          String // OIL_CHANGE, TIRE, BRAKE, INSPECTION, OTHER
  description   String?
  scheduledDate DateTime
  completedDate DateTime?
  status        MaintenanceStatus @default(SCHEDULED)
  cost          Float?
  createdAt     DateTime          @default(now())
}

model TrackingSession {
  id        String    @id @default(cuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  deviceId  String
  startTime DateTime  @default(now())
  endTime   DateTime?
  status    String    @default("ACTIVE")
}

// ─── PASSENGER MANAGEMENT ─────────────────────────────────────────────────────

model Passenger {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])

  name           String
  photoUrl       String?
  nationality    String?
  motherTongue   String?
  dob            DateTime?
  grade          String? // for schools
  pickupAddress  String?
  dropoffAddress String?
  notes          String?
  active         Boolean   @default(true)

  guardians     Guardian[]
  scheduleItems SchedulePassenger[]
  tripEvents    TripEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guardian {
  id          String    @id @default(cuid())
  passengerId String
  passenger   Passenger @relation(fields: [passengerId], references: [id])
  userId      String? // if guardian has a platform account (PARENT role)
  user        User?     @relation(fields: [userId], references: [id])

  name               String
  relationship       String // MOTHER, FATHER, GRANDPARENT, OTHER
  phonePrimary       String?
  phoneSecondary     String?
  email              String?
  isEmergencyContact Boolean @default(false)
  isPrimary          Boolean @default(false)

  createdAt DateTime @default(now())
}

// ─── ROUTES & STOPS ───────────────────────────────────────────────────────────

model Route {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])

  name        String
  description String?
  active      Boolean @default(true)

  stops     Stop[]
  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Trip      Trip[]
}

model Stop {
  id        String  @id @default(cuid())
  routeId   String
  route     Route   @relation(fields: [routeId], references: [id])
  name      String
  latitude  Float
  longitude Float
  address   String?
  sequence  Int

  pickupItems  SchedulePassenger[] @relation("PickupStop")
  dropoffItems SchedulePassenger[] @relation("DropoffStop")
  tripEvents   TripEvent[]
}

// ─── SCHEDULING ───────────────────────────────────────────────────────────────

model Schedule {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  routeId        String?
  route          Route?       @relation(fields: [routeId], references: [id])
  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id])
  driverUserId   String?

  name           String
  type           ScheduleType @default(RECURRING)
  recurrenceRule String? // RRULE string e.g. FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR
  startTime      String? // HH:MM
  endTime        String? // HH:MM
  daysOfWeek     String[]
  effectiveFrom  DateTime?
  effectiveTo    DateTime?

  status        ScheduleStatus @default(PENDING_APPROVAL)
  approvedById  String?
  approvedAt    DateTime?
  rejectionNote String?
  requestNote   String? // note from requester for extra/special trips

  passengers SchedulePassenger[]
  trips      Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchedulePassenger {
  id            String    @id @default(cuid())
  scheduleId    String
  schedule      Schedule  @relation(fields: [scheduleId], references: [id])
  passengerId   String
  passenger     Passenger @relation(fields: [passengerId], references: [id])
  pickupStopId  String?
  pickupStop    Stop?     @relation("PickupStop", fields: [pickupStopId], references: [id])
  dropoffStopId String?
  dropoffStop   Stop?     @relation("DropoffStop", fields: [dropoffStopId], references: [id])
  isSelfPickup  Boolean   @default(false)

  @@unique([scheduleId, passengerId])
}

// ─── TRIP OPERATIONS ──────────────────────────────────────────────────────────

model Trip {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  scheduleId     String?
  schedule       Schedule?    @relation(fields: [scheduleId], references: [id])
  routeId        String?
  route          Route?       @relation(fields: [routeId], references: [id])
  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id])
  driverUserId   String?
  driver         User?        @relation("TripDriver", fields: [driverUserId], references: [id])

  date      DateTime   @default(now())
  status    TripStatus @default(CREATED)
  startedAt DateTime?
  endedAt   DateTime?
  notes     String?

  events      TripEvent[]
  emergencies EmergencyAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TripEvent {
  id          String     @id @default(cuid())
  tripId      String
  trip        Trip       @relation(fields: [tripId], references: [id])
  passengerId String?
  passenger   Passenger? @relation(fields: [passengerId], references: [id])
  stopId      String?
  stop        Stop?      @relation(fields: [stopId], references: [id])

  action       TripAction
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  notes        String?
  recordedById String?
  recordedBy   User?      @relation("RecordedBy", fields: [recordedById], references: [id])
  timestamp    DateTime   @default(now())
}

// ─── EMERGENCY ────────────────────────────────────────────────────────────────

model EmergencyAlert {
  id             String    @id @default(cuid())
  tripId         String?
  trip           Trip?     @relation(fields: [tripId], references: [id])
  organisationId String
  reportedById   String
  latitude       Float?
  longitude      Float?
  description    String?
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  source         String    @default("DRIVER")
  timestamp      DateTime  @default(now())
}

// ─── DRIVER SHIFTS ────────────────────────────────────────────────────────────

model DriverShift {
  id              String        @id @default(cuid())
  driverProfileId String
  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
  date            DateTime
  startTime       String
  endTime         String
  status          String        @default("SCHEDULED")
  createdAt       DateTime      @default(now())
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model NotificationLog {
  id             String              @id @default(cuid())
  organisationId String
  organisation   Organisation        @relation(fields: [organisationId], references: [id])
  recipientId    String?
  recipient      User?               @relation(fields: [recipientId], references: [id])
  channel        NotificationChannel
  templateKey    String
  payloadJson    Json
  status         NotificationStatus  @default(PENDING)
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
}

// ─── BULK IMPORT ──────────────────────────────────────────────────────────────

model ImportJob {
  id              String       @id @default(cuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id])
  type            ImportType
  filename        String
  fileUrl         String
  status          ImportStatus @default(PENDING)
  totalRows       Int?
  processedRows   Int?
  errorRows       Int?
  errorDetailJson Json?
  previewJson     Json? // rows extracted, pending review
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  actorId        String?
  actor          User?        @relation("AuditActor", fields: [actorId], references: [id])
  actorRole      String?

  entityType   String // "Passenger", "Trip", "Schedule", etc.
  entityId     String
  action       String // "CREATE", "UPDATE", "DELETE", "APPROVE", etc.
  oldValueJson Json?
  newValueJson Json?
  ipAddress    String?
  userAgent    String?
  severity     LogSeverity @default(INFO)
  timestamp    DateTime    @default(now())

  @@index([organisationId, entityType, entityId])
  @@index([timestamp])
}

// ─── SYSTEM ───────────────────────────────────────────────────────────────────

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AcademicCalendar {
  id             String    @id @default(cuid())
  organisationId String
  branchId       String?
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           String    @default("EVENT")
  isPublic       Boolean   @default(true)
  color          String?   @default("#1E3A8A")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
